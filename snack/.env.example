PORT=3000
NODE_ENV=development

# MySQL/MariaDB
# - 호스트에서 Nest 실행: docker compose up -d 후 아래 localhost URL
# - compose 안 컨테이너: mysql://admin:admin@mysql:3306/snack
# 로컬 DB 띄울 때: 프로젝트 루트에서 `docker compose up -d` → MySQL 준비 후 자동 `migrate deploy`
# 스키마 변경 반영(개발): npx prisma migrate dev
# 배포 서버: npx prisma migrate deploy (또는 프로덕션 Dockerfile entrypoint)
DATABASE_URL="mysql://admin:admin@localhost:3306/snack"

# 비밀번호 재설정 메일 링크 베이스 URL (CORS는 서버에서 전 출처 허용)
FRONTEND_URL="http://localhost:5173"

COOKIE_DOMAIN="localhost"
COOKIE_SECURE=false
COOKIE_SAMESITE="lax"

JWT_ACCESS_SECRET="your_access_secret"
JWT_REFRESH_SECRET="your_refresh_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

BCRYPT_ROUNDS=12

# 전역 HTTP rate limit (main.ts express-rate-limit)
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# DB 딥 헬스(/api/health/db). 프로덕션에서 설정 시 x-health-db-secret 헤더 필수. 미설정 시 프로덕션에서는 해당 경로 비공개.
# HEALTH_DB_SECRET=

AUTH_THROTTLE_TTL=60
AUTH_THROTTLE_LIMIT=5

# Redis (로컬: HOST/PORT · Railway 등: REDIS_URL 하나만 써도 됨)
# REDIS_URL 이 비어 있으면 REDIS_PORT(및 REDIS_HOST) 필수 — 기본 포트는 여기서만 지정하고 코드에 숫자 상수를 두지 않습니다.
# REDIS_URL=redis://...
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# SMTP (이메일 발송)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@snack.local

# 초대 링크 만료 시간 (시간, 7일 = 168)
INVITATION_EXPIRES_HOURS=168

# 비밀번호 재설정 (선택)
# PASSWORD_RESET_EXPIRES_IN=1h
# PASSWORD_RESET_PATH=/reset-password