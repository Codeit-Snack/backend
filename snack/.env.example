PORT=3000
NODE_ENV=development

DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/snack"

FRONTEND_URL="http://localhost:5173"

COOKIE_DOMAIN="localhost"
COOKIE_SECURE=false
COOKIE_SAMESITE="lax"

JWT_ACCESS_SECRET="your_access_secret"
JWT_REFRESH_SECRET="your_refresh_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

BCRYPT_ROUNDS=12

THROTTLE_TTL=60
THROTTLE_LIMIT=10

AUTH_THROTTLE_TTL=60
AUTH_THROTTLE_LIMIT=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# SMTP (이메일 발송)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@snack.local

# 초대 링크 만료 시간 (시간, 7일 = 168)
INVITATION_EXPIRES_HOURS=168